# Frontend Configuration

# Production (main site — www.timekidspreschools.in):
#   NEXT_PUBLIC_CANONICAL_SITE_URL=https://www.timekidspreschools.in
#   NEXT_PUBLIC_API_BASE_URL=https://www.timekidspreschools.in/api
#   NEXT_PUBLIC_SERVER_URL=https://www.timekidspreschools.in
#   Required for correct gallery/admin image previews if /media is not nginx-proxied to Django:
#   NEXT_PUBLIC_API_BASE_URL=https://www.timekidspreschools.in/api
#   Or set explicitly: NEXT_PUBLIC_MEDIA_BASE_URL=https://www.timekidspreschools.in/media
#   Same-server Node+Django: set INTERNAL_API_URL=http://127.0.0.1:8000 (next.config proxies /media → Django)

# For Server-Side Rendering (Optional)
# If your backend is running in a different container or internal network
# INTERNAL_API_URL=http://backend:8000

# Local development examples:
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
# NEXT_PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000/media
